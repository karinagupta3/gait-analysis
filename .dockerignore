# Keep the ACR build context small — the image installs deps from requirements.txt
# and downloads the pose model itself.
.venv/
venv/
env/
.git/
__pycache__/
**/__pycache__/
*.pyc
models/*
# ...but DO include the two OpenSim models so the tier-2 worker image can bake them.
!models/LaiUhlrich2022.osim
!models/LaiUhlrich2022_ga.osim
data/
outputs/
*.mov
*.mp4
*.npz
*.trc
*.mot
*.osim
*.task
*.onnx
.rtmlib/
src/gait_analysis/web/_data/
tests/
docs/
